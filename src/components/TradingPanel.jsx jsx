import React, { useState } from 'react';
import PositionsList from './PositionsList';
import OrderHistory from './OrderHistory';
import EmotionModal from './EmotionModal';
import './TradingPanel.css';

function TradingPanel({
  selectedCoin,
  virtualBalance,
  setVirtualBalance,
  positions,
  setPositions,
  orders,
  setOrders,
  marketData,
  tradeHistory,
  setTradeHistory
}) {
  const [orderType, setOrderType] = useState('market');
  const [side, setSide] = useState('buy');
  const [amount, setAmount] = useState('');
  const [price, setPrice] = useState('');
  const [stopLoss, setStopLoss] = useState('');
  const [takeProfit, setTakeProfit] = useState('');
  const [showEmotionModal, setShowEmotionModal] = useState(false);
  const [lastTrade, setLastTrade] = useState(null);

  const currentPrice = marketData[selectedCoin]?.price || 0;

  const handleExecuteTrade = () => {
    const tradeAmount = parseFloat(amount);
    const tradePrice = orderType === 'market' ? currentPrice : parseFloat(price);
    
    if (isNaN(tradeAmount) || tradeAmount <= 0) {
      alert('Please enter valid amount');
      return;
    }

    const totalCost = tradeAmount * tradePrice;

    if (side === 'buy') {
      if (totalCost > virtualBalance) {
        alert('Insufficient virtual balance!');
        return;
      }
      
      const newPosition = {
        id: Date.now(),
        coin: selectedCoin,
        side: 'buy',
        amount: tradeAmount,
        entryPrice: tradePrice,
        currentPrice: tradePrice,
        stopLoss: stopLoss ? parseFloat(stopLoss) : null,
        takeProfit: takeProfit ? parseFloat(takeProfit) : null,
        timestamp: new Date().toISOString(),
      };
      
      setPositions([...positions, newPosition]);
      setVirtualBalance(virtualBalance - totalCost);
      setLastTrade({ ...newPosition, type: 'buy' });
    } else {
      // Sell logic
      const existingPosition = positions.find(p => p.coin === selectedCoin && p.side === 'buy');
      if (!existingPosition) {
        alert('No position to sell!');
        return;
      }
      
      const pnl = (tradePrice - existingPosition.entryPrice) * existingPosition.amount;
      
      const completedTrade = {
        id: Date.now(),
        coin: selectedCoin,
        entryPrice: existingPosition.entryPrice,
        exitPrice: tradePrice,
        amount: existingPosition.amount,
        pnl: pnl,
        timestamp: new Date().toISOString(),
      };
      
      setTradeHistory([completedTrade, ...tradeHistory]);
      setVirtualBalance(virtualBalance + (existingPosition.amount * tradePrice));
      setPositions(positions.filter(p => p.id !== existingPosition.id));
      setLastTrade({ ...completedTrade, type: 'sell' });
    }
    
    setAmount('');
    setPrice('');
    setStopLoss('');
    setTakeProfit('');
    setShowEmotionModal(true);
  };

  const handleQuickTopUp = () => {
    setVirtualBalance(virtualBalance + 1000);
  };

  const maxAmount = side === 'buy' 
    ? virtualBalance / currentPrice 
    : positions.find(p => p.coin === selectedCoin)?.amount || 0;

  return (
    <div className="trading-panel">
      <div className="trading-header">
        <h3>TRADE</h3>
        <button className="topup-btn" onClick={handleQuickTopUp}>+ Add Funds</button>
      </div>
      
      <div className="order-type-tabs">
        <button className={`order-tab ${orderType === 'market' ? 'active' : ''}`} onClick={() => setOrderType('market')}>
          MARKET
        </button>
        <button className={`order-tab ${orderType === 'limit' ? 'active' : ''}`} onClick={() => setOrderType('limit')}>
          LIMIT
        </button>
      </div>
      
      <div className="side-buttons">
        <button className={`side-btn buy ${side === 'buy' ? 'active' : ''}`} onClick={() => setSide('buy')}>
          BUY
        </button>
        <button className={`side-btn sell ${side === 'sell' ? 'active' : ''}`} onClick={() => setSide('sell')}>
          SELL
        </button>
      </div>
      
      <div className="trade-inputs">
        <div className="input-group">
          <label>Amount ({selectedCoin.replace('USDT', '')})</label>
          <input
            type="number"
            value={amount}
            onChange={(e) => setAmount(e.target.value)}
            placeholder={`Max: ${maxAmount.toFixed(6)}`}
          />
          <button className="max-btn" onClick={() => setAmount(maxAmount.toString())}>MAX</button>
        </div>
        
        {orderType === 'limit' && (
          <div className="input-group">
            <label>Limit Price (USDT)</label>
            <input
              type="number"
              value={price}
              onChange={(e) => setPrice(e.target.value)}
              placeholder={`Current: $${currentPrice}`}
            />
          </div>
        )}
        
        <div className="input-group">
          <label>Stop Loss (Optional)</label>
          <input
            type="number"
            value={stopLoss}
            onChange={(e) => setStopLoss(e.target.value)}
            placeholder="Price for stop loss"
          />
        </div>
        
        <div className="input-group">
          <label>Take Profit (Optional)</label>
          <input
            type="number"
            value={takeProfit}
            onChange={(e) => setTakeProfit(e.target.value)}
            placeholder="Price for take profit"
          />
        </div>
      </div>
      
      <div className="trade-summary">
        <div className="summary-row">
          <span>Total Cost:</span>
          <span>${((parseFloat(amount) || 0) * (orderType === 'market' ? currentPrice : (parseFloat(price) || currentPrice))).toFixed(2)}</span>
        </div>
        <div className="summary-row">
          <span>Available Balance:</span>
          <span>${virtualBalance.toFixed(2)}</span>
        </div>
      </div>
      
      <button className={`execute-btn ${side}`} onClick={handleExecuteTrade}>
        {side === 'buy' ? 'BUY' : 'SELL'} {selectedCoin.replace('USDT', '')}
      </button>
      
      <PositionsList positions={positions} marketData={marketData} />
      <OrderHistory orders={tradeHistory} />
      
      {showEmotionModal && (
        <EmotionModal
          onClose={() => setShowEmotionModal(false)}
          trade={lastTrade}
        />
      )}
    </div>
  );
}

export default TradingPanel;
